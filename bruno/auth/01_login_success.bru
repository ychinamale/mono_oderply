meta {
  name: Login - success
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{operatorEmail}}",
    "password": "{{operatorPassword}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.token);
  }
}

assert {
  res.status: eq 200
  res.body.token: isDefined
  res.body.operator.email: eq admin@oderply.com
}
