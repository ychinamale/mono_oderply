meta {
  name: List audit logs
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/panics/{{panicId}}/logs
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

script:post-response {
  if (res.status === 200 && res.body.data.length > 0) {
    bru.setEnvVar("logId", res.body.data[0].id);
  }
}

assert {
  res.status: eq 200
  res.body.data: isDefined
  res.body.pagination: isDefined
}
