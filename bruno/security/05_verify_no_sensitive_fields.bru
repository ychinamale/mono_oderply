meta {
  name: Security - no apiKeyHash in panic response
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/v1/panics/{{panicId}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

assert {
  res.status: eq 200
  res.body.partner.apiKeyHash: isUndefined
  res.body.claimedByPartner.apiKeyHash: isUndefined
}
