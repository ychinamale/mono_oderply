meta {
  name: Security - invalid API key
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/panics
  body: json
  auth: none
}

headers {
  x-api-key: totally-fake-key
}

body:json {
  {
    "externalUserId": "x",
    "latitude": 0,
    "longitude": 0,
    "idempotencyKey": "{{$randomUUID}}"
  }
}

assert {
  res.status: eq 403
}
